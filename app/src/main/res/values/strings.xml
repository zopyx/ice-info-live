    <!-- Info Dialog -->
    <string name="info_version">Version %1$s</string>
    <string name="info_description">Diese App liest Live-Daten aus der ICE Portal API des Deutsche Bahn ICE-WLANs aus und zeigt sie übersichtlich an. Für Bahnhofsinformationen werden außerdem offizielle APIs der Deutschen Bahn genutzt.</string>
    <string name="info_privacy_title">Datenschutz</string>
    <string name="info_privacy_text">Diese App speichert oder erfasst keine personenbezogenen Daten. Fahrtdaten werden über die interne API im Zug-WLAN abgerufen. Bahnhofsdaten (Ausstattung, Aufzugsstatus) werden über öffentliche APIs der Deutschen Bahn aus dem Internet geladen.</string>
    <string name="info_api_title">API</string>
    <string name="info_api_url1">https://iceportal.de/api1/rs/status</string>
    <string name="info_api_url2">https://iceportal.de/api1/rs/tripInfo/trip</string>
    <string name="info_api_url3">https://iceportal.de/api1/rs/pois/all</string>
    <string name="info_api_url4">https://iceportal.de/api1/rs/tripInfo/connection/{eva_nummer}</string>
    <string name="info_api_title_db">Offizielle DB APIs (CC BY 4.0)</string>
    <string name="info_api_db_stada">DB StaDa – Station Data v2</string>
    <string name="info_api_db_fasta">DB FaSta – Facility Status v2</string>
    <string name="info_api_db_wagenreihung">DB Wagenreihung – bahn.de</string>
    <string name="info_api_title_community">Community APIs</string>
    <string name="info_api_community_transport">v6.db.transport.rest (db.transport.rest)</string>
    <string name="info_built_with_title">Entwickelt mit</string>
    <string name="info_built_with_text">Kotlin · Jetpack Compose · OSMDroid · Material 3</string>
    <string name="info_legal_title">Rechtliches</string>
    <string name="info_legal_1">Dies ist eine inoffizielle App. Für die Richtigkeit der angezeigten Daten kann keine Haftung übernommen werden.</string>
    <string name="info_legal_2">Diese App steht in keiner Verbindung mit der DB Fernverkehr AG, DB Systel GmbH oder anderen Tochterunternehmen der Deutsche Bahn AG.</string>
    <string name="info_legal_3">Diese App steht in keiner Verbindung mit der Siemens Mobility GmbH</string>
    <string name="info_legal_5">Diese App steht in keiner Verbindung mit Bombardier Transportation / Alstrom</string>
    <string name="info_legal_6">Diese App steht in keiner Verbindung mit Talgo</string>
    <string name="info_legal_4">Das ICEportal.de und die ICEportal API werden von der DB Systel GmbH bereitgestellt.</string>
